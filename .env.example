# LLM provider for clip scoring and publishing metadata.
# MiniMax M3 example:
LLM_PROVIDER=minimax
LLM_BASE_URL=https://api.minimax.io/v1/text/chatcompletion_v2
LLM_API_KEY=
LLM_MODEL=MiniMax-M3

# Optional aliases accepted by the app.
MINIMAX_API_URL=https://api.minimax.io/v1/text/chatcompletion_v2
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M3
OPENCODE_BASE_URL=
OPENCODE_API_KEY=
OPENCODE_MODEL=

# Optional OpenAI-compatible local fallback example:
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1:8b

# Optional OpenAI STT. If omitted, provide --transcript or upload an SRT/VTT/JSON transcript.
STT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Future local transcription target.
TRANSCRIPTION_PROVIDER=faster-whisper
TRANSCRIPTION_MODEL=small
TRANSCRIPTION_LANGUAGE=auto

# Future publishing API credentials. Never commit real tokens.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/oauth/youtube/callback
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_CATEGORY_ID=22
META_GRAPH_VERSION=v23.0
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/oauth/instagram/callback
META_INSTAGRAM_SCOPES=pages_show_list,pages_read_engagement,instagram_basic,instagram_content_publish
META_INSTAGRAM_OMIT_SCOPES=false
META_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://amaliogomezlopez.github.io/YOUTUBE-EDIT/oauth/tiktok/callback/
TIKTOK_SCOPES=user.info.basic,user.info.profile,video.upload
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_OPEN_ID=
X_API_KEY=
X_API_SECRET=

# Optional HTTPS asset host for Instagram Reels. Instagram Graph API needs a
# public HTTPS video_url; local MP4 files are uploaded here before publishing.
ASSET_HOST_PROVIDER=
ASSET_HOST_SSH_HOST=
ASSET_HOST_SSH_PORT=22
ASSET_HOST_SSH_USER=
ASSET_HOST_SSH_KEY_PATH=
ASSET_HOST_REMOTE_DIR=
ASSET_HOST_PUBLIC_BASE_URL=

# Server
PORT=3000
